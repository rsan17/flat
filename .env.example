# Copy to .env.local and fill in. Server-only unless prefixed NEXT_PUBLIC_.

# Mono acquiring (https://api.monobank.ua/docs/acquiring.html)
MONO_API_TOKEN=

# Nova Poshta API (https://developers.novaposhta.ua/)
NOVA_POSHTA_API_KEY=

# Supabase
NEXT_PUBLIC_SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=

# Resend
RESEND_API_KEY=
ADMIN_EMAIL=

# Public site URL for Mono redirectUrl / webHookUrl
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Telegram bot для сповіщень про нові замовлення
# chat_id отримати: написати боту /start, потім https://api.telegram.org/bot<TOKEN>/getUpdates
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
# Окремий chat_id для нотифікацій про реєстрації в F5 Chess Club (можна кілька через кому)
TELEGRAM_CLUB_CHAT_ID=
